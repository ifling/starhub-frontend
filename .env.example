# Backend
API_PORT=8000
# 开发 H5（Vite）跨域请写明来源，可与 JWT 同时使用 credentials：
# CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# 若用 * 则后端会自动关闭 allow_credentials（仍可带 Authorization: Bearer，一般可正常注册/登录）
CORS_ALLOW_ORIGINS=*

# JWT (set a long random string in production)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_MINUTES=10080

# WeChat mini program (server-side code2session)
WECHAT_MP_APPID=
WECHAT_MP_SECRET=

# QQ mini program (server-side jscode2session)
QQ_MP_APPID=
QQ_MP_SECRET=

# Postgres
POSTGRES_DB=starhub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
