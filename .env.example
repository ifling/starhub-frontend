# Backend
API_PORT=8000
# * 时使用 allow_origin_regex，响应会回显请求的 Origin（本地 H5 如 http://127.0.0.1:5173 可带 Bearer）
# 也可显式列举：CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_ORIGINS=*

# JWT (set a long random string in production)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_MINUTES=10080

# WeChat mini program (server-side code2session)
WECHAT_MP_APPID=
WECHAT_MP_SECRET=

# QQ mini program (server-side jscode2session)
QQ_MP_APPID=
QQ_MP_SECRET=

# Postgres
POSTGRES_DB=starhub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
